<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="500.0" minWidth="800.0" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #f0f0f0; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
               <children>
                  <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" text="Current" />
                  <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" text="Desired" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label text="Medicine Manager">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" style="-fx-background-color: white;">
               <children>
                  <TextField prefHeight="30.0" prefWidth="300.0" promptText="Search..." />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" prefHeight="30.0" text="Add New" />
                  <Button mnemonicParsing="false" prefHeight="30.0" text="Edit" />
                  <Button mnemonicParsing="false" prefHeight="30.0" text="Delete" />
               </children>
               <padding>
                  <Insets left="20.0" right="20.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <AnchorPane BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="mainTable" prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="10.0">
              <columns>
                <TableColumn prefWidth="250.0" text="Name" />
                  <TableColumn prefWidth="150.0" text="Category" />
                  <TableColumn prefWidth="120.0" text="Quantity" />
                  <TableColumn prefWidth="150.0" text="Expiry Date" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </AnchorPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="30.0" style="-fx-background-color: #f9f9f9; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Ready" textFill="#666666" />
         </children>
         <padding>
            <Insets left="20.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>
